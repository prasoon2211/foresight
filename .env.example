# Copy to .env to override docker compose's development defaults.
# Generate production values independently; never commit the resulting .env.
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_SECRET_KEY_FALLBACKS=
ENCRYPTION_SALT_KEYS=replace-with-a-long-random-salt
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ACCOUNT_CONFIRM_EMAIL_URL=http://localhost:5173/verify-email/{key}
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=false
DJANGO_DEFAULT_FROM_EMAIL=foresight@localhost
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_URL=https://api.github.com
EXECUTOR_TYPE=fake
DAYTONA_API_KEY=
OPENCODE_VERSION=1.17.18
OPENCODE_MODEL=anthropic/claude-sonnet-4-5
WEB_PORT=8000

POSTGRES_DB=foresight
POSTGRES_USER=foresight
POSTGRES_PASSWORD=replace-with-a-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
